# .env.example
# IMPORTANTE: Copia este archivo a .env y completa los valores correspondientes.
# NO subas el .env real al repositorio (está en .gitignore)

# Credenciales maestras (Utilizadas SOLO por el build de Docker Compose)
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=change_me_to_a_secure_password
DB_NAME=library_db

# Cadena de conexión estricta de Aplicación (Next.js)
# NOTA SEGURA: Nunca conecta como el usuario 'postgres', usa un rol de mínimo privilegio
DATABASE_URL=postgres://app_reporter:Secure_Reporter_P@ss@127.0.0.1:5432/library_db
